---
import BaseHead from "../../components/BaseHead.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../../consts";
import { getCollection } from "astro:content";
import { shouldIncludePost } from "../../content/visibility";

const allPosts = await getCollection("blog", ({ data }) => shouldIncludePost(data.published));
const tags = [...new Set(allPosts.map((post) => post.data.tags).flat())].filter(
  Boolean
);
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <BaseHead title={`Tags | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
    <style>
      main {
        width: 960px;
      }
      .tags {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
        justify-content: center;
        margin: 2rem 0;
      }
      .tag {
        display: inline-block;
        padding: 0.5em 1em;
        background-color: rgba(var(--gray-light), 0.5);
        color: rgb(var(--black));
        border-radius: 20px;
        text-decoration: none;
        font-weight: bold;
        transition: background-color 0.2s ease, transform 0.2s ease;
      }
      .tag:hover {
        background-color: var(--accent);
        color: white;
        transform: translateY(-2px);
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <section>
        <h1 style="text-align: center;">All Tags</h1>
        <div class="tags">
          {
            tags.map((tag) => (
              <a class="tag" href={`/tags/${tag}/`}>
                {tag}
              </a>
            ))
          }
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>
