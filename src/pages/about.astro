---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";
import Layout from "../layouts/BlogPost.astro";

// 経歴データ
const timelineData = [
	{ year: "2020", content: "プログラミング学習開始" },
	{ year: "2022", content: "Node.jsでのバックエンド開発にのめり込む" },
	{ year: "2024", content: "自宅サーバーでのインフラ構築" },
	{ year: "2026", content: "Astroでブログ開設" },
];
---

<!DOCTYPE html>
<html lang="ja">
	<head>
		<BaseHead title={`About | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0 auto;
			}
			.prose {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1em;
				color: rgb(var(--gray-dark));
			}

			.about-container {
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: 2em;
				min-height: 50vh; /* 1画面におさまりやすくする */
				padding: 2em 0;
			}

			.about-content {
				flex: 1;
			}

			.about-content h3 {
				margin-bottom: 1em;
				font-size: 2em;
			}

			.about-content ul {
				list-style: none;
				padding: 0;
				font-size: 1.1em;
			}

			.about-content li {
				margin-bottom: 0.8em;
			}

			.about-icon {
				flex: 0 0 200px; /* アイコンサイズ */
				display: flex;
				justify-content: center;
			}

			.about-icon img {
				width: 100%;
				max-width: 200px;
				height: auto;
				aspect-ratio: 1 / 1;
				object-fit: cover;
				border-radius: 50%;
				box-shadow: var(--box-shadow);
			}

			/* スマホ表示時などは縦並びにする */
			@media (max-width: 720px) {
				.about-container {
					flex-direction: column-reverse;
					text-align: center;
				}

				.about-content ul {
					text-align: left;
					display: inline-block;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<article>
				<div class="prose">
					<div class="about-container">
						<div class="about-content">
							<h3>よつ (@ulxsth)</h3>
							<ul>
								<li>趣味: 開発、ゲーム</li>
								<li>好きな技術: Node.js, Astro</li>
								<li>興味あること: ネットワーク, インフラ構築</li>
							</ul>
						</div>
						<div class="about-icon">
							<img
								src="https://pbs.twimg.com/profile_images/1762092141843722240/BfwOdl39_400x400.jpg"
								alt="yotu icon"
							/>
						</div>
					</div>
				</div>

				<div class="timeline-section">
					<h2 class="section-title">Timeline</h2>
					<div class="timeline-list">
						{
							timelineData.map((item) => (
								<div class="timeline-item">
									<div class="timeline-year">{item.year}</div>
									<div class="timeline-content">{item.content}</div>
								</div>
							))
						}
					</div>
				</div>
			</article>
		</main>
		<Footer />
		<style>
			/* 既存のstyleの最後に追加 */

			.timeline-section {
				margin-top: 4em;
				padding-top: 2em;
			}

			.section-title {
				text-align: center;
				margin-bottom: 2em;
				font-size: 1.8em;
			}

			.timeline-list {
				display: flex;
				flex-direction: column;
				gap: 1.2em;
				max-width: 500px;
				margin: 0 auto;
			}

			.timeline-item {
				display: flex;
				gap: 2em;
				align-items: center;
			}

			.timeline-year {
				font-weight: bold;
				color: var(--accent);
				flex: 0 0 4em;
				text-align: right;
			}

			.timeline-content {
				flex: 1;
				color: rgb(var(--gray-dark));
			}

			@media (max-width: 720px) {
				.timeline-item {
					gap: 1.5em;
				}
				.timeline-year {
					text-align: left;
					flex: 0 0 3em;
				}
			}
		</style>
	</body>
</html>
