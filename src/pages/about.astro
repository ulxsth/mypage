---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";
import Layout from "../layouts/BlogPost.astro";

// 経歴データ
const timelineData = [
	{
		year: "2020",
		title: "プログラミング学習開始",
		description: "初めてHTMLとCSSを書き、Webの仕組みに感動する。",
		iconUrl: "https://cdn-icons-png.flaticon.com/512/1005/1005141.png",
	},
	{
		year: "2022",
		title: "Node.jsとの出会い",
		description:
			"JavaScriptでサーバーサイドが書けることに衝撃を受け、バックエンド開発にのめり込む。",
		iconUrl: "https://cdn-icons-png.flaticon.com/512/919/919832.png",
	},
	{
		year: "2024",
		title: "インフラ構築に興味を持つ",
		description: "自宅サーバーを建ててネットワーク周りの知識を深める。",
		iconUrl: "https://cdn-icons-png.flaticon.com/512/2888/2888691.png",
	},
	{
		year: "2026",
		title: "Astroでブログ開設",
		description: "備忘録や日々の記録を残すためのサイトを開設。",
		iconUrl: "https://cdn-icons-png.flaticon.com/512/3721/3721262.png",
	},
];
---

<!DOCTYPE html>
<html lang="ja">
	<head>
		<BaseHead title={`About | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0 auto;
			}
			.prose {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1em;
				color: rgb(var(--gray-dark));
			}

			.about-container {
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: 2em;
				min-height: 50vh; /* 1画面におさまりやすくする */
				padding: 2em 0;
			}

			.about-content {
				flex: 1;
			}

			.about-content h3 {
				margin-bottom: 1em;
				font-size: 2em;
			}

			.about-content ul {
				list-style: none;
				padding: 0;
				font-size: 1.1em;
			}

			.about-content li {
				margin-bottom: 0.8em;
			}

			.about-icon {
				flex: 0 0 200px; /* アイコンサイズ */
				display: flex;
				justify-content: center;
			}

			.about-icon img {
				width: 100%;
				max-width: 200px;
				height: auto;
				aspect-ratio: 1 / 1;
				object-fit: cover;
				border-radius: 50%;
				box-shadow: var(--box-shadow);
			}

			/* スマホ表示時などは縦並びにする */
			@media (max-width: 720px) {
				.about-container {
					flex-direction: column-reverse;
					text-align: center;
				}

				.about-content ul {
					text-align: left;
					display: inline-block;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<article>
				<div class="prose">
					<div class="about-container">
						<div class="about-content">
							<h3>よつ (@ulxsth)</h3>
							<ul>
								<li>趣味: 開発、ゲーム</li>
								<li>好きな技術: Node.js, Astro</li>
								<li>興味あること: ネットワーク, インフラ構築</li>
							</ul>
						</div>
						<div class="about-icon">
							<img
								src="https://pbs.twimg.com/profile_images/1762092141843722240/BfwOdl39_400x400.jpg"
								alt="yotu icon"
							/>
						</div>
					</div>
				</div>

				<div class="timeline-section">
					<h2 class="section-title">Timeline</h2>
					<div class="timeline-wrapper">
						<div class="timeline-scroll">
							{
								timelineData.map((item, index) => (
									<div class="timeline-node-container">
										<div class="timeline-node">
											<img src={item.iconUrl} alt={item.title} />
											<div class="timeline-tooltip">
												<div class="tooltip-year">{item.year}</div>
												<div class="tooltip-title">{item.title}</div>
												<div class="tooltip-desc">{item.description}</div>
											</div>
										</div>
										<div class="timeline-year-label">{item.year}</div>
										{index < timelineData.length - 1 && (
											<div class="timeline-connector" />
										)}
									</div>
								))
							}
						</div>
					</div>
				</div>
			</article>
		</main>
		<Footer />
		<style>
			/* 既存のstyleの最後に追加 */

			.timeline-section {
				margin-top: 4em;
				padding-top: 2em;
				border-top: 1px solid rgb(var(--gray-light));
			}

			.section-title {
				text-align: center;
				margin-bottom: 2em;
				font-size: 1.8em;
			}

			.timeline-wrapper {
				width: 100%;
				overflow-x: auto;
				/* スクロールバーをおしゃれにする設定 */
				padding-bottom: 2em;
			}

			/* Webkitのスクロールバーカスタマイズ */
			.timeline-wrapper::-webkit-scrollbar {
				height: 8px;
			}
			.timeline-wrapper::-webkit-scrollbar-track {
				background: rgb(var(--gray-light));
				border-radius: 4px;
			}
			.timeline-wrapper::-webkit-scrollbar-thumb {
				background: var(--accent);
				border-radius: 4px;
			}

			.timeline-scroll {
				display: inline-flex;
				align-items: flex-start;
				padding: 2em 1em; /* ツールチップがはみ出ないように上下に余白を設ける */
				min-width: 100%; /* 中身が少なくても左寄せ・中央寄せなどをコントロールしやすくする */
				box-sizing: border-box;
			}

			.timeline-node-container {
				display: flex;
				flex-direction: column;
				align-items: center;
				position: relative;
			}

			.timeline-connector {
				position: absolute;
				top: 30px; /* ノードの高さの半分 */
				left: 50%;
				width: 250px; /* ノード間の距離 */
				height: 4px;
				background-color: var(--accent);
				/* Zインデックスでノードの後ろに置く */
				z-index: 1;
			}

			.timeline-node {
				width: 60px;
				height: 60px;
				border-radius: 50%;
				background-color: white;
				border: 4px solid var(--accent);
				display: flex;
				justify-content: center;
				align-items: center;
				position: relative;
				z-index: 2; /* コネクタの上に表示 */
				cursor: pointer;
				margin: 0 95px; /* (250px - 60px) / 2 でコネクタの幅と合わせる */
			}

			.timeline-node img {
				width: 32px;
				height: 32px;
				object-fit: contain;
			}

			.timeline-year-label {
				margin-top: 1em;
				font-weight: bold;
				color: rgb(var(--gray));
			}

			/* ツールチップのデザイン */
			.timeline-tooltip {
				position: absolute;
				bottom: 120%; /* ノードの上に出す */
				left: 50%;
				transform: translateX(-50%) translateY(10px);
				background-color: rgb(var(--gray-dark));
				color: white;
				padding: 1em;
				border-radius: 8px;
				width: 200px;
				opacity: 0;
				visibility: hidden;
				transition: all 0.3s ease;
				box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
				pointer-events: none; /* ホバーの邪魔をしない */
			}

			/* ツールチップの吹き出ししっぽ部分 */
			.timeline-tooltip::after {
				content: "";
				position: absolute;
				top: 100%;
				left: 50%;
				margin-left: -8px;
				border-width: 8px;
				border-style: solid;
				border-color: rgb(var(--gray-dark)) transparent transparent transparent;
			}

			.timeline-node:hover .timeline-tooltip {
				opacity: 1;
				visibility: visible;
				transform: translateX(-50%) translateY(0);
			}

			.tooltip-year {
				font-size: 0.8em;
				color: var(--accent);
				margin-bottom: 0.2em;
			}

			.tooltip-title {
				font-weight: bold;
				margin-bottom: 0.5em;
				border-bottom: 1px solid rgba(255, 255, 255, 0.2);
				padding-bottom: 0.5em;
			}

			.tooltip-desc {
				font-size: 0.85em;
				line-height: 1.4;
			}
		</style>
	</body>
</html>
