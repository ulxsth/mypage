---
import AboutHeroImage from "../assets/blog-placeholder-about.jpg";
import Layout from "../layouts/BlogPost.astro";
---

<Layout
	title="About Me"
	description="Lorem ipsum dolor sit amet"
	pubDate={new Date("August 08 2021")}
	heroImage={AboutHeroImage}
>
	<div class="about-container">
		<div class="about-content">
			<h3>よつ (@ulxsth)</h3>
			<ul>
				<li>趣味: 開発、ゲーム</li>
				<li>好きな技術: Node.js, Astro</li>
				<li>興味あること: ネットワーク, インフラ構築</li>
				<li>ひと言: 備忘録やメモ書きを垂れ流します。</li>
			</ul>
		</div>
		<div class="about-icon">
			<img src="/blog-placeholder-about.webp" alt="yotu icon" />
		</div>
	</div>
</Layout>

<style>
	.about-container {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 2em;
		min-height: 50vh; /* 1画面におさまりやすくする */
		padding: 2em 0;
	}

	.about-content {
		flex: 1;
	}

	.about-content h3 {
		margin-bottom: 1em;
		font-size: 2em;
	}

	.about-content ul {
		list-style: none;
		padding: 0;
		font-size: 1.1em;
	}

	.about-content li {
		margin-bottom: 0.8em;
	}

	.about-icon {
		flex: 0 0 300px; /* アイコンの基本サイズ */
		display: flex;
		justify-content: center;
	}

	.about-icon img {
		width: 100%;
		max-width: 250px;
		height: auto;
		aspect-ratio: 1 / 1;
		object-fit: cover;
		border-radius: 50%;
		box-shadow: var(--box-shadow);
	}

	/* スマホ表示時などは縦並びにする */
	@media (max-width: 720px) {
		.about-container {
			flex-direction: column-reverse;
			text-align: center;
		}

		.about-content ul {
			text-align: left;
			display: inline-block; /* 中央揃えの中で左揃えのブロックを作る */
		}
	}
</style>
