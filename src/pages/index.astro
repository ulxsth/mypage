---
import { getCollection } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import FormattedDate from "../components/FormattedDate.astro";
import Header from "../components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";

// ブログ記事を取得し、日付が新しい順に並び替え、先頭5件を取得
const posts = (await getCollection("blog"))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 5);
---

<!DOCTYPE html>
<html lang="ja">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 960px;
			}
			.section-title {
				margin-bottom: 2rem;
				text-align: center;
				font-size: 2rem;
			}
			ul {
				display: flex;
				flex-direction: column;
				gap: 0;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			ul li {
				width: 100%;
				border-bottom: 1px solid rgba(var(--gray), 0.2);
			}
			ul li:last-child {
				border-bottom: none;
			}
			ul li * {
				text-decoration: none;
			}
			ul li a {
				display: flex;
				align-items: center;
				padding: 1.5rem 1rem;
				gap: 1.5rem;
				color: inherit;
				border-radius: 12px;
				transition: background 0.2s ease;
			}
			ul li a:hover {
				background: rgba(var(--gray-light), 0.3);
			}
			.post-icon {
				flex: 0 0 80px;
				height: 80px;
				background: #0b1426; /* 画像に合わせたダークネイビー */
				border-radius: 16px;
				display: flex;
				align-items: center;
				justify-content: center;
				font-size: 2.5rem;
				box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
			}
			.post-content {
				flex: 1;
				display: flex;
				flex-direction: column;
				justify-content: center;
			}
			.title {
				margin: 0 0 0.5rem 0;
				color: rgb(var(--black));
				line-height: 1.4;
				font-size: 1.35rem;
				font-weight: bold;
				transition: color 0.2s ease;
			}
			.meta {
				display: flex;
				align-items: center;
				gap: 0.6rem;
				font-size: 0.95rem;
				color: rgb(var(--gray));
			}
			.author-avatar {
				width: 24px;
				height: 24px;
				border-radius: 50%;
				object-fit: cover;
			}
			.author-name {
				color: rgb(var(--black));
				font-weight: 500;
			}
			ul li a:hover .title {
				color: var(--accent);
			}
			.more-link {
				display: block;
				text-align: center;
				margin-top: 3rem;
				font-size: 1.2rem;
				color: var(--accent);
				text-decoration: none;
			}
			.more-link:hover {
				text-decoration: underline;
			}
			@media (max-width: 720px) {
				ul li a {
					padding: 1rem 0.5rem;
					gap: 1rem;
				}
				.post-icon {
					flex: 0 0 60px;
					height: 60px;
					font-size: 2rem;
					border-radius: 12px;
				}
				.title {
					font-size: 1.15rem;
				}
				.meta {
					font-size: 0.85rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section>
				<h2 class="section-title">Latest Posts</h2>
				<ul>
					{
						posts.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`}>
									<div class="post-icon">{post.data.icon || "📝"}</div>
									<div class="post-content">
										<h4 class="title">{post.data.title}</h4>
										<div class="meta">
											<img
												class="author-avatar"
												src="https://pbs.twimg.com/profile_images/1762092141843722240/BfwOdl39_400x400.jpg"
												alt="yotu"
											/>
											<span class="author-name">yotu</span>
											<FormattedDate date={post.data.pubDate} />
										</div>
									</div>
								</a>
							</li>
						))
					}
				</ul>

				<a href="/blog" class="more-link">もっと見る &rarr;</a>
			</section>
		</main>
		<Footer />
	</body>
</html>
