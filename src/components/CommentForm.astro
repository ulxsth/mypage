---
---

<div class="comment-section">
  <h3>コメントを送信</h3>
  <small>記事の感想や修正依頼等を送っていただけるとよろこびます</small>
  <form id="comment-form" class="comment-form">
    <div class="form-group">
      <label for="email">メールアドレス *</label>
      <input type="email" id="email" name="email" required />
    </div>

    <div class="form-group">
      <label for="message">コメント *</label>
      <textarea id="message" name="message" rows="5" required></textarea>
    </div>

    <button type="submit" class="submit-btn">送信</button>
    <div class="form-message" id="form-message"></div>
  </form>
</div>

<script>
  const formEl = document.getElementById('comment-form');
  const messageDivEl = document.getElementById('form-message');

  if (!(formEl instanceof HTMLFormElement) || !(messageDivEl instanceof HTMLDivElement)) {
    throw new Error('Comment form elements not found');
  }

  const form = formEl;
  const messageDiv = messageDivEl;
  let currentMessage = '';
  let currentType = 'error';

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    const emailInput = document.getElementById('email');
    const messageInput = document.getElementById('message');

    if (!(emailInput instanceof HTMLInputElement) || !(messageInput instanceof HTMLTextAreaElement)) {
      currentMessage = 'フォーム要素が見つかりません';
      currentType = 'error';
      renderMessage();
      return;
    }

    const email = emailInput.value.trim();
    const message = messageInput.value.trim();

    if (!email || !message) {
      currentMessage = 'すべてのフィールドを入力してください';
      currentType = 'error';
      renderMessage();
      return;
    }

    // ボタンを無効化
    const submitBtn = form.querySelector('button[type="submit"]');
    if (!(submitBtn instanceof HTMLButtonElement)) {
      currentMessage = '送信ボタンが見つかりません';
      currentType = 'error';
      renderMessage();
      return;
    }
    submitBtn.disabled = true;
    submitBtn.textContent = '送信中...';

    try {
      const response = await fetch('/api/comments', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({
          email,
          message,
        }),
      });

      const data = await response.json();

      if (response.ok) {
        currentMessage = 'コメントを送信しました！';
        currentType = 'success';
        renderMessage();
        form.reset();
      } else {
        currentMessage = data.error || 'エラーが発生しました';
        currentType = 'error';
        renderMessage();
      }
    } catch (error) {
      console.error('Error:', error);
      currentMessage = '通信エラーが発生しました';
      currentType = 'error';
      renderMessage();
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = '送信';
    }
  });

  const renderMessage = () => {
    messageDiv.textContent = currentMessage;
    messageDiv.className = `form-message form-message--${currentType}`;
    messageDiv.style.display = 'block';

    if (currentType === 'success') {
      setTimeout(() => {
        messageDiv.style.display = 'none';
      }, 3000);
    }
  };
</script>

<style>
  .comment-section {
    width: 85%;
    max-width: calc(100% - 2em);
    margin: 3em auto;
    padding: 2em;
    border-top: 2px solid var(--gray-light);
  }

  .comment-section h3 {
    margin-top: 0;
    margin-bottom: 1.5em;
    color: var(--gray-dark);
  }

  .comment-form {
    display: flex;
    flex-direction: column;
    gap: 1.5em;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5em;
  }

  label {
    font-weight: 600;
    color: var(--gray-dark);
    font-size: 0.95em;
  }

  input[type='text'],
  input[type='email'],
  textarea {
    padding: 0.75em;
    border: 1px solid var(--gray-light);
    border-radius: 6px;
    font-family: inherit;
    font-size: 1em;
    color: var(--gray-dark);
    background-color: var(--surface);
    transition: border-color 0.2s, background-color 0.2s, color 0.2s;
  }

  input[type='text']::placeholder,
  input[type='email']::placeholder,
  textarea::placeholder {
    color: var(--gray);
  }

  input[type='text']:focus,
  input[type='email']:focus,
  textarea:focus {
    outline: none;
    border-color: var(--accent);
  }

  textarea {
    resize: vertical;
    min-height: 120px;
  }

  .submit-btn {
    padding: 0.75em 1.5em;
    background-color: var(--accent);
    color: white;
    border: none;
    border-radius: 6px;
    font-weight: 600;
    cursor: pointer;
    transition: opacity 0.2s;
    align-self: flex-start;
  }

  .submit-btn:hover:not(:disabled) {
    opacity: 0.9;
  }

  .submit-btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .form-message {
    display: none;
    padding: 1em;
    border-radius: 6px;
    font-weight: 500;
  }

  .form-message--success {
    background-color: #d4edda;
    color: #155724;
    border: 1px solid #c3e6cb;
  }

  .form-message--error {
    background-color: #f8d7da;
    color: #721c24;
    border: 1px solid #f5c6cb;
  }

  @media (max-width: 768px) {
    .comment-section {
      width: 100%;
      padding: 1.5em 1em;
    }

    input[type='text'],
    input[type='email'],
    textarea {
      font-size: 16px;
    }
  }
</style>
